{
    "editor.formatOnSave": true,
    "typescript.tsdk": "web-app/node_modules/typescript/lib",
    "[python]": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "charliermarsh.ruff"
    },
    "[javascript]": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "biomejs.biome"
    },
    "[javascriptreact]": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "biomejs.biome"
    },
    "[typescript]": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "biomejs.biome"
    },
    "[typescriptreact]": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "biomejs.biome"
    },
    "[json]": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "biomejs.biome"
    },
    "[jsonc]": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "biomejs.biome"
    },
    "editor.codeActionsOnSave": {
        "source.fixAll.biome": "explicit",
        "source.organizeImports.biome": "explicit"
    },
    "biome.lsp.bin": "web-app/node_modules/.bin/biome",
    "biome.configurationPath": "web-app/biome.json",
    "biome.enabled": true,
    "python-envs.pythonProjects": [],
    "cSpell.words": [
        "async_engine",
        "async_session",
        "async_session_factory",
        "async_sessionmaker",
        "autocommit",
        "autoflush",
        "engine",
        "expire_on_commit",
        "pyproject",
        "sessionmaker",
        "Smol",
        "SQLModel",
        "Ultracite",
        "outerjoin",
    ]
}